generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  OWNER_VIEW
  MANAGER
  PAYROLL
  SERVICE
  ADMIN
  CUSTOMER_SERVICE
}

enum PayrollPeriodStatus {
  OPEN
  LOCKED
  FINALIZED
}

enum PayrollEntryStatus {
  PENDING
  READY
  PAID
  ZEROED_OUT
  CLAWBACK_APPLIED
}

enum SaleStatus {
  RAN
  DECLINED
  DEAD
}

enum ChangeRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ClawbackStatus {
  OPEN
  MATCHED
  DEDUCTED
  ZEROED
}

enum ProductType {
  CORE
  ADDON
  AD_D
  ACA_PL
}

model User {
  id           String     @id @default(cuid())
  name         String
  email        String     @unique
  username     String?
  passwordHash String     @map("password_hash")
  roles        UserRole[] @default([])
  active       Boolean    @default(true)
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  enteredSales                 Sale[]                 @relation("SaleEnteredBy")
  reviews                      CallAudit[]            @relation("AuditReviewer")
  statusChangeRequestsMade     StatusChangeRequest[]  @relation("StatusChangeRequester")
  statusChangeRequestsReviewed StatusChangeRequest[]  @relation("StatusChangeReviewer")
  saleEditRequestsMade         SaleEditRequest[]      @relation("SaleEditRequester")
  saleEditRequestsReviewed     SaleEditRequest[]      @relation("SaleEditReviewer")
  chargebackSubmissions        ChargebackSubmission[] @relation("ChargebackSubmittedBy")
  pendingTermSubmissions       PendingTerm[]          @relation("PendingTermSubmittedBy")
  resolvedChargebacks          ChargebackSubmission[] @relation("ChargebackResolvedBy")
  resolvedPendingTerms         PendingTerm[]          @relation("PendingTermResolvedBy")
  permissionOverrides          PermissionOverride[]
  grantedPermissions           PermissionOverride[]   @relation("PermissionGrantedBy")

  @@map("users")
}

model Agent {
  id           String   @id @default(cuid())
  name         String
  email        String?  @unique
  userId       String?  @map("user_id")
  extension    String?
  active       Boolean  @default(true)
  auditEnabled   Boolean   @default(false) @map("audit_enabled")
  auditEnabledAt DateTime? @map("audit_enabled_at")
  displayOrder Int      @default(0) @map("display_order")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  sales              Sale[]
  audits             CallAudit[]
  payrollEntries     PayrollEntry[]
  clawbacks          Clawback[]
  convosoCallLogs    ConvosoCallLog[]
  callKpis           AgentCallKpi[]
  periodAdjustments  AgentPeriodAdjustment[]

  @@map("agents")
}

model LeadSource {
  id                String   @id @default(cuid())
  name              String   @unique
  listId            String?  @map("list_id")
  costPerLead       Decimal  @map("cost_per_lead") @db.Decimal(10, 2)
  active            Boolean  @default(true)
  callBufferSeconds Int      @default(0) @map("call_buffer_seconds")
  effectiveDate     DateTime @map("effective_date")
  notes             String?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  sales           Sale[]
  convosoCallLogs ConvosoCallLog[]
  callKpis        AgentCallKpi[]

  @@map("lead_sources")
}

model Product {
  id                   String      @id @default(cuid())
  name                 String      @unique
  active               Boolean     @default(true)
  type                 ProductType @default(CORE)
  premiumThreshold     Decimal?    @map("premium_threshold") @db.Decimal(12, 2)
  commissionBelow      Decimal?    @map("commission_below") @db.Decimal(5, 2)
  commissionAbove      Decimal?    @map("commission_above") @db.Decimal(5, 2)
  bundledCommission    Decimal?    @map("bundled_commission") @db.Decimal(5, 2)
  standaloneCommission Decimal?    @map("standalone_commission") @db.Decimal(5, 2)
  enrollFeeThreshold   Decimal?    @map("enroll_fee_threshold") @db.Decimal(10, 2)
  flatCommission       Decimal?    @map("flat_commission") @db.Decimal(12, 2)
  notes                String?

  requiredBundleAddonId  String?  @map("required_bundle_addon_id")

  requiredBundleAddon    Product? @relation("RequiredBundleAddon", fields: [requiredBundleAddonId], references: [id])

  // Reverse relations (required by Prisma for self-referencing)
  coreProductsRequiring  Product[] @relation("RequiredBundleAddon")

  // Many-to-many fallback addons via join table
  fallbackAddons         CoreProductFallback[] @relation("CoreFallbacks")
  fallbackForCores       CoreProductFallback[] @relation("FallbackFor")

  stateAvailability      ProductStateAvailability[]

  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")

  sales            Sale[]
  payoutRules      PayoutRule[]
  saleAddons       SaleAddon[]
  clawbackProducts ClawbackProduct[]

  @@map("products")
}

model ProductStateAvailability {
  id         String   @id @default(cuid())
  productId  String   @map("product_id")
  stateCode  String   @map("state_code") @db.VarChar(2)
  createdAt  DateTime @default(now()) @map("created_at")

  product    Product  @relation(fields: [productId], references: [id])

  @@unique([productId, stateCode])
  @@map("product_state_availability")
}

model CoreProductFallback {
  id                String   @id @default(cuid())
  coreProductId     String   @map("core_product_id")
  fallbackProductId String   @map("fallback_product_id")
  createdAt         DateTime @default(now()) @map("created_at")

  coreProduct       Product  @relation("CoreFallbacks", fields: [coreProductId], references: [id], onDelete: Cascade)
  fallbackProduct   Product  @relation("FallbackFor", fields: [fallbackProductId], references: [id], onDelete: Cascade)

  @@unique([coreProductId, fallbackProductId])
  @@map("core_product_fallbacks")
}

model Sale {
  id              String             @id @default(cuid())
  saleDate        DateTime           @map("sale_date")
  agentId         String             @map("agent_id")
  memberName      String             @map("member_name")
  memberId        String?            @map("member_id")
  carrier         String
  productId       String             @map("product_id")
  premium         Decimal            @db.Decimal(12, 2)
  effectiveDate   DateTime           @map("effective_date")
  leadSourceId    String             @map("lead_source_id")
  status          SaleStatus         @default(RAN)
  notes           String?
  enteredByUserId String             @map("entered_by_user_id")
  payrollStatus   PayrollEntryStatus @default(PENDING) @map("payroll_status")
  clawbackStatus  ClawbackStatus     @default(OPEN) @map("clawback_status")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  enrollmentFee      Decimal?  @map("enrollment_fee") @db.Decimal(10, 2)
  commissionApproved Boolean   @default(false) @map("commission_approved")
  paymentType        String?   @map("payment_type")
  recordingUrl       String?   @map("recording_url")
  convosoLeadId      String?   @map("convoso_lead_id")
  callDuration       Int?      @map("call_duration")
  callDateTime       DateTime? @map("call_date_time")
  memberState        String?   @map("member_state") @db.VarChar(2)
  leadPhone          String?   @map("lead_phone")
  memberCount        Int?      @map("member_count")
  acaCoveringSaleId  String?   @map("aca_covering_sale_id")

  agent                Agent                 @relation(fields: [agentId], references: [id])
  product              Product               @relation(fields: [productId], references: [id])
  leadSource           LeadSource            @relation(fields: [leadSourceId], references: [id])
  enteredByUser        User                  @relation("SaleEnteredBy", fields: [enteredByUserId], references: [id])
  payrollEntries       PayrollEntry[]
  clawbacks            Clawback[]
  addons               SaleAddon[]
  statusChangeRequests StatusChangeRequest[]
  saleEditRequests     SaleEditRequest[]
  matchedChargebacks   ChargebackSubmission[] @relation("ChargebackMatchedSale")
  acaCoveringSale      Sale?                  @relation("AcaCovering", fields: [acaCoveringSaleId], references: [id])
  acaCoveredSales      Sale[]                 @relation("AcaCovering")

  @@index([saleDate])
  @@index([memberId])
  @@index([leadSourceId, createdAt])
  @@map("sales")
}

model CallAudit {
  id                   String   @id @default(cuid())
  agentId              String   @map("agent_id")
  callDate             DateTime @map("call_date")
  score                Int
  status               String
  coachingNotes        String?  @map("coaching_notes")
  reviewerUserId       String?  @map("reviewer_user_id")
  transcription        String?
  aiSummary            String?  @map("ai_summary")
  aiScore              Int?     @map("ai_score")
  aiCoachingNotes      String?  @map("ai_coaching_notes")
  recordingUrl         String?  @map("recording_url")
  callOutcome          String?  @map("call_outcome")
  callDurationEstimate String?  @map("call_duration_estimate")
  issues               Json?
  wins                 Json?
  missedOpportunities  Json?    @map("missed_opportunities")
  suggestedCoaching    Json?    @map("suggested_coaching")
  managerSummary       String?  @map("manager_summary")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  agent          Agent           @relation(fields: [agentId], references: [id])
  reviewer       User?           @relation("AuditReviewer", fields: [reviewerUserId], references: [id])
  convosoCallLog ConvosoCallLog?

  @@map("call_audits")
}

model PayrollPeriod {
  id           String              @id @default(cuid())
  weekStart    DateTime            @map("week_start")
  weekEnd      DateTime            @map("week_end")
  quarterLabel String              @map("quarter_label")
  year         Int
  status             PayrollPeriodStatus @default(OPEN)
  carryoverExecuted  Boolean             @default(false) @map("carryover_executed")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")

  entries            PayrollEntry[]
  serviceEntries     ServicePayrollEntry[]
  clawbacks          Clawback[]
  approvedAlerts     PayrollAlert[] @relation("AlertApprovedPeriod")
  agentAdjustments   AgentPeriodAdjustment[]

  @@map("payroll_periods")
}

model PayoutRule {
  id            String   @id @default(cuid())
  productId     String   @map("product_id")
  payoutAmount  Decimal  @map("payout_amount") @db.Decimal(10, 2)
  active        Boolean  @default(true)
  effectiveDate DateTime @map("effective_date")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  product Product @relation(fields: [productId], references: [id])

  @@index([productId, effectiveDate])
  @@map("payout_rules")
}

model PayrollEntry {
  id               String             @id @default(cuid())
  payrollPeriodId  String             @map("payroll_period_id")
  saleId           String             @map("sale_id")
  agentId          String             @map("agent_id")
  payoutAmount     Decimal            @map("payout_amount") @db.Decimal(12, 2)
  adjustmentAmount Decimal            @default(0) @map("adjustment_amount") @db.Decimal(12, 2)
  bonusAmount      Decimal            @default(0) @map("bonus_amount") @db.Decimal(12, 2)
  frontedAmount    Decimal            @default(0) @map("fronted_amount") @db.Decimal(12, 2)
  holdAmount       Decimal            @default(0) @map("hold_amount") @db.Decimal(12, 2)
  halvingReason    String?            @map("halving_reason")
  netAmount        Decimal            @map("net_amount") @db.Decimal(12, 2)
  status           PayrollEntryStatus @default(PENDING)
  paidAt           DateTime?          @map("paid_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  payrollPeriod PayrollPeriod @relation(fields: [payrollPeriodId], references: [id])
  sale          Sale          @relation(fields: [saleId], references: [id])
  agent         Agent         @relation(fields: [agentId], references: [id])

  @@unique([payrollPeriodId, saleId])
  @@map("payroll_entries")
}

model SaleAddon {
  id        String   @id @default(cuid())
  saleId    String   @map("sale_id")
  productId String   @map("product_id")
  premium   Decimal? @db.Decimal(12, 2)
  createdAt DateTime @default(now()) @map("created_at")

  sale    Sale    @relation(fields: [saleId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@unique([saleId, productId])
  @@map("sale_addons")
}

model StatusChangeRequest {
  id          String              @id @default(cuid())
  saleId      String              @map("sale_id")
  requestedBy String              @map("requested_by")
  requestedAt DateTime            @default(now()) @map("requested_at")
  oldStatus   SaleStatus
  newStatus   SaleStatus
  status      ChangeRequestStatus @default(PENDING)
  reviewedBy  String?             @map("reviewed_by")
  reviewedAt  DateTime?           @map("reviewed_at")
  createdAt   DateTime            @default(now()) @map("created_at")

  sale      Sale  @relation(fields: [saleId], references: [id], onDelete: Cascade)
  requester User  @relation("StatusChangeRequester", fields: [requestedBy], references: [id])
  reviewer  User? @relation("StatusChangeReviewer", fields: [reviewedBy], references: [id])

  @@index([saleId])
  @@index([status])
  @@map("status_change_requests")
}

model SaleEditRequest {
  id          String              @id @default(cuid())
  saleId      String              @map("sale_id")
  requestedBy String              @map("requested_by")
  requestedAt DateTime            @default(now()) @map("requested_at")
  changes     Json // { field: { old: value, new: value } }
  status      ChangeRequestStatus @default(PENDING)
  reviewedBy  String?             @map("reviewed_by")
  reviewedAt  DateTime?           @map("reviewed_at")
  createdAt   DateTime            @default(now()) @map("created_at")

  sale      Sale  @relation(fields: [saleId], references: [id], onDelete: Cascade)
  requester User  @relation("SaleEditRequester", fields: [requestedBy], references: [id])
  reviewer  User? @relation("SaleEditReviewer", fields: [reviewedBy], references: [id])

  @@index([saleId])
  @@index([status])
  @@map("sale_edit_requests")
}

model Clawback {
  id                     String         @id @default(cuid())
  saleId                 String         @map("sale_id")
  agentId                String         @map("agent_id")
  matchedBy              String         @map("matched_by")
  matchedValue           String         @map("matched_value")
  amount                 Decimal        @db.Decimal(12, 2)
  status                 ClawbackStatus @default(MATCHED)
  appliedPayrollPeriodId String?        @map("applied_payroll_period_id")
  notes                  String?
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")

  sale                 Sale           @relation(fields: [saleId], references: [id])
  agent                Agent          @relation(fields: [agentId], references: [id])
  appliedPayrollPeriod PayrollPeriod? @relation(fields: [appliedPayrollPeriodId], references: [id])
  clawbackProducts     ClawbackProduct[]

  @@map("clawbacks")
}

model ClawbackProduct {
  id          String   @id @default(cuid())
  clawbackId  String   @map("clawback_id")
  productId   String   @map("product_id")
  amount      Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now()) @map("created_at")

  clawback Clawback @relation(fields: [clawbackId], references: [id])
  product  Product  @relation(fields: [productId], references: [id])

  @@unique([clawbackId, productId])
  @@map("clawback_products")
}

model SalesBoardSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("sales_board_settings")
}

model PermissionOverride {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  permission String   // "create:sale", "create:chargeback", "create:pending_term", "create:rep", "create:agent", "create:product", "create:lead_source"
  granted    Boolean  @default(true)
  grantedBy  String   @map("granted_by")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user    User @relation(fields: [userId], references: [id])
  grantor User @relation("PermissionGrantedBy", fields: [grantedBy], references: [id])

  @@unique([userId, permission])
  @@map("permission_overrides")
}

model ServiceAgent {
  id        String   @id @default(cuid())
  name      String
  basePay   Decimal  @map("base_pay") @db.Decimal(12, 2)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  payrollEntries ServicePayrollEntry[]
  csRepRoster    CsRepRoster?

  @@map("service_agents")
}

model ServicePayrollEntry {
  id              String             @id @default(cuid())
  serviceAgentId  String             @map("service_agent_id")
  payrollPeriodId String             @map("payroll_period_id")
  basePay         Decimal            @map("base_pay") @db.Decimal(12, 2)
  bonusAmount     Decimal            @default(0) @map("bonus_amount") @db.Decimal(12, 2)
  deductionAmount Decimal            @default(0) @map("deduction_amount") @db.Decimal(12, 2)
  frontedAmount   Decimal            @default(0) @map("fronted_amount") @db.Decimal(12, 2)
  totalPay        Decimal            @map("total_pay") @db.Decimal(12, 2)
  bonusBreakdown  Json?              @map("bonus_breakdown")
  status          PayrollEntryStatus @default(PENDING)
  notes           String?
  paidAt          DateTime?          @map("paid_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  serviceAgent  ServiceAgent  @relation(fields: [serviceAgentId], references: [id])
  payrollPeriod PayrollPeriod @relation(fields: [payrollPeriodId], references: [id])

  @@unique([payrollPeriodId, serviceAgentId])
  @@map("service_payroll_entries")
}

model AppAuditLog {
  id          String   @id @default(cuid())
  actorUserId String?  @map("actor_user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String?  @map("entity_id")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("app_audit_log")
}

model ConvosoCallLog {
  id                  String   @id @default(cuid())
  agentUser           String   @map("agent_user")
  listId              String   @map("list_id")
  recordingUrl        String?  @map("recording_url")
  callDurationSeconds Int?     @map("call_duration_seconds")
  callTimestamp       DateTime @default(now()) @map("call_timestamp")
  agentId             String?  @map("agent_id")
  leadSourceId        String?  @map("lead_source_id")
  transcription       String?
  auditStatus         String   @default("pending") @map("audit_status")
  callAuditId         String?  @unique @map("call_audit_id")
  createdAt           DateTime @default(now()) @map("created_at")
  leadPhone           String?  @map("lead_phone")
  retryCount          Int      @default(0) @map("retry_count")
  lastFailedAt        DateTime? @map("last_failed_at")
  failureReason       String?  @map("failure_reason")

  agent      Agent?      @relation(fields: [agentId], references: [id])
  leadSource LeadSource? @relation(fields: [leadSourceId], references: [id])
  callAudit  CallAudit?  @relation(fields: [callAuditId], references: [id])

  @@index([callTimestamp])
  @@index([agentId, leadSourceId, callTimestamp])
  @@index([leadSourceId, callTimestamp])
  @@map("convoso_call_logs")
}

model AiUsageLog {
  id            String   @id @default(cuid())
  callLogId     String?  @map("call_log_id")
  model         String   // e.g. "claude-sonnet-4-20250514"
  inputTokens   Int      @map("input_tokens")
  outputTokens  Int      @map("output_tokens")
  estimatedCost Decimal  @map("estimated_cost") @db.Decimal(10, 6)
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("ai_usage_logs")
}

model AgentCallKpi {
  id                 String   @id @default(cuid())
  agentId            String   @map("agent_id")
  leadSourceId       String   @map("lead_source_id")
  convosoUserId      String   @map("convoso_user_id")
  totalCalls         Int      @map("total_calls")
  avgCallLength      Decimal  @map("avg_call_length") @db.Decimal(10, 2)
  callsByTier        Json     @map("calls_by_tier")
  costPerSale        Decimal? @map("cost_per_sale") @db.Decimal(10, 2)
  totalLeadCost      Decimal? @map("total_lead_cost") @db.Decimal(10, 2)
  longestCall        Int      @default(0) @map("longest_call")
  conversionEligible Boolean  @default(false) @map("conversion_eligible")
  snapshotDate       DateTime @default(now()) @map("snapshot_date")
  createdAt          DateTime @default(now()) @map("created_at")

  agent      Agent      @relation(fields: [agentId], references: [id])
  leadSource LeadSource @relation(fields: [leadSourceId], references: [id])

  @@index([agentId, leadSourceId, snapshotDate])
  @@index([snapshotDate])
  @@map("agent_call_kpis")
}

model ProcessedConvosoCall {
  id            String   @id @default(cuid())
  convosoCallId String   @unique @map("convoso_call_id")
  leadSourceId  String?  @map("lead_source_id")
  processedAt   DateTime @default(now()) @map("processed_at")

  @@index([processedAt])
  @@map("processed_convoso_calls")
}

model ServiceTicket {
  id        String   @id @default(cuid())
  title     String
  status    String   @default("OPEN")
  details   String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("service_tickets")
}

model ChargebackSubmission {
  id                     String    @id @default(cuid())
  postedDate             DateTime? @map("posted_date")
  type                   String?
  payeeId                String?   @map("payee_id")
  payeeName              String?   @map("payee_name")
  payoutPercent          Decimal?  @map("payout_percent") @db.Decimal(5, 2)
  chargebackAmount       Decimal?  @map("chargeback_amount") @db.Decimal(12, 2)
  totalAmount            Decimal?  @map("total_amount") @db.Decimal(12, 2)
  transactionDescription String?   @map("transaction_description")
  product                String?
  memberCompany          String?   @map("member_company")
  memberId               String?   @map("member_id")
  memberAgentCompany     String?   @map("member_agent_company")
  memberAgentId          String?   @map("member_agent_id")
  submittedBy            String    @map("submitted_by")
  submittedAt            DateTime  @default(now()) @map("submitted_at")
  batchId                String    @map("batch_id")
  rawPaste               String    @map("raw_paste")
  assignedTo             String?   @map("assigned_to")
  resolvedAt             DateTime? @map("resolved_at")
  resolvedBy             String?   @map("resolved_by")
  resolutionNote         String?   @map("resolution_note")
  resolutionType         String?   @map("resolution_type")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  matchedSaleId  String?  @map("matched_sale_id")
  matchStatus    String?  @map("match_status")

  matchedSale Sale?  @relation("ChargebackMatchedSale", fields: [matchedSaleId], references: [id])
  submitter   User   @relation("ChargebackSubmittedBy", fields: [submittedBy], references: [id])
  resolver    User?  @relation("ChargebackResolvedBy", fields: [resolvedBy], references: [id])
  alerts      PayrollAlert[]

  @@map("chargeback_submissions")
}

model PayrollAlert {
  id                     String    @id @default(cuid())
  chargebackSubmissionId String    @map("chargeback_submission_id")
  agentId                String?   @map("agent_id")
  agentName              String?   @map("agent_name")
  customerName           String?   @map("customer_name")
  amount                 Decimal?  @db.Decimal(12, 2)
  status                 String    @default("PENDING") // PENDING, APPROVED, CLEARED
  approvedPeriodId       String?   @map("approved_period_id")
  approvedBy             String?   @map("approved_by")
  approvedAt             DateTime? @map("approved_at")
  clearedBy              String?   @map("cleared_by")
  clearedAt              DateTime? @map("cleared_at")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  chargeback     ChargebackSubmission @relation(fields: [chargebackSubmissionId], references: [id])
  approvedPeriod PayrollPeriod?       @relation("AlertApprovedPeriod", fields: [approvedPeriodId], references: [id])

  @@map("payroll_alerts")
}

model CsRepRoster {
  id             String        @id @default(cuid())
  name           String
  active         Boolean       @default(true)
  serviceAgentId String?       @unique @map("service_agent_id")
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  serviceAgent   ServiceAgent? @relation(fields: [serviceAgentId], references: [id])

  @@map("cs_rep_roster")
}

model PendingTerm {
  id                  String    @id @default(cuid())
  agentName           String?   @map("agent_name")
  agentIdField        String?   @map("agent_id_field")
  memberId            String?   @map("member_id")
  memberName          String?   @map("member_name")
  city                String?
  state               String?
  phone               String?
  email               String?
  product             String?
  enrollAmount        Decimal?  @map("enroll_amount") @db.Decimal(12, 2)
  monthlyAmount       Decimal?  @map("monthly_amount") @db.Decimal(12, 2)
  paid                String?
  createdDate         DateTime? @map("created_date")
  firstBilling        DateTime? @map("first_billing")
  activeDate          DateTime? @map("active_date")
  nextBilling         DateTime? @map("next_billing")
  holdDate            DateTime? @map("hold_date") @db.Date
  holdReason          String?   @map("hold_reason")
  inactive            Boolean?  @default(false)
  lastTransactionType String?   @map("last_transaction_type")
  assignedTo          String?   @map("assigned_to")
  smoker              String?
  batchId             String    @map("batch_id")
  submittedBy         String    @map("submitted_by")
  submittedAt         DateTime  @default(now()) @map("submitted_at")
  rawPaste            String    @map("raw_paste")
  resolvedAt          DateTime? @map("resolved_at")
  resolvedBy          String?   @map("resolved_by")
  resolutionNote      String?   @map("resolution_note")
  resolutionType      String?   @map("resolution_type")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  submitter User  @relation("PendingTermSubmittedBy", fields: [submittedBy], references: [id])
  resolver  User? @relation("PendingTermResolvedBy", fields: [resolvedBy], references: [id])

  @@map("pending_terms")
}

model AgentPeriodAdjustment {
  id                      String   @id @default(cuid())
  agentId                 String   @map("agent_id")
  payrollPeriodId         String   @map("payroll_period_id")
  bonusAmount             Decimal  @default(0) @map("bonus_amount") @db.Decimal(12, 2)
  frontedAmount           Decimal  @default(0) @map("fronted_amount") @db.Decimal(12, 2)
  holdAmount              Decimal  @default(0) @map("hold_amount") @db.Decimal(12, 2)
  bonusLabel              String?  @map("bonus_label")
  holdLabel               String?  @map("hold_label")
  bonusFromCarryover      Boolean  @default(false) @map("bonus_from_carryover")
  holdFromCarryover       Boolean  @default(false) @map("hold_from_carryover")
  carryoverSourcePeriodId String?  @map("carryover_source_period_id")
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  agent         Agent         @relation(fields: [agentId], references: [id])
  payrollPeriod PayrollPeriod @relation(fields: [payrollPeriodId], references: [id])

  @@unique([agentId, payrollPeriodId])
  @@map("agent_period_adjustments")
}
