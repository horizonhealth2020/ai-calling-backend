NODE_ENV=production
ALLOWED_ORIGINS=http://localhost:3011,http://localhost:3012,http://localhost:3013,http://localhost:3014,http://localhost:3019,http://localhost:3026
CONVOSO_WEBHOOK_SECRET=change-this-to-a-secure-random-string
