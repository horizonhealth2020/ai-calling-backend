{
  "name": "@ops/ops-api",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "prisma generate --schema ../../prisma/schema.prisma && tsc -p tsconfig.json",
    "start": "prisma migrate deploy --schema ../../prisma/schema.prisma && tsx src/index.ts",
    "prisma:migrate": "prisma migrate deploy --schema ../../prisma/schema.prisma",
    "prisma:seed": "tsx ../../prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@ops/auth": "*",
    "@ops/db": "*",
    "@ops/types": "*",
    "@ops/utils": "*",
    "@prisma/client": "^5.20.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "openai": "^4.73.0",
    "prisma": "^5.20.0",
    "socket.io": "^4.8.3",
    "tsx": "^4.19.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "typescript": "^5.6.2"
  }
}
