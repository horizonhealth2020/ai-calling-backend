{
  "name": "ai-calling-backend",
  "version": "1.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "ops:dev": "npm --prefix apps/ops-api run dev",
    "auth:dev": "npm --prefix apps/auth-portal run dev",
    "manager:dev": "npm --prefix apps/manager-dashboard run dev",
    "payroll:dev": "npm --prefix apps/payroll-dashboard run dev",
    "owner:dev": "npm --prefix apps/owner-dashboard run dev",
    "salesboard:dev": "npm --prefix apps/sales-board run dev",
    "db:migrate": "npm --prefix apps/ops-api run prisma:migrate",
    "db:seed": "npm --prefix apps/ops-api run prisma:seed",
    "test:ops": "jest --config apps/ops-api/jest.config.ts"
  },
  "dependencies": {
    "axios": "^1.7.7",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "lucide-react": "^0.577.0",
    "luxon": "^3.4.4",
    "node-cron": "^3.0.3",
    "node-fetch": "^2.6.11",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": "20.x"
  },
  "packageManager": "npm@10.8.2"
}
